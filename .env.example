# Environment Configuration — GarmentOS

# ─── Database ─────────────────────────────────────────────────────────────────
# Local PostgreSQL (Docker)
# NOTE: Special characters in passwords must be URL-encoded in DATABASE_URL
# e.g. @ → %40, # → %23, ! → %21
# Example: password "Abhi@1998" becomes "Abhi%401998" in the URL
DATABASE_URL="postgresql://garmentos:Abhi%401998@localhost:5432/garmentos_db"

# Production (Neon / Supabase — replace with your connection string)
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key_here"
EMAIL_FROM="noreply@garmentos.com"

# ─── File Storage ─────────────────────────────────────────────────────────────
# For local development (files stored in /uploads)
STORAGE_PROVIDER="local"
UPLOAD_DIR="./public/uploads"

# For production S3/R2 (set STORAGE_PROVIDER="s3")
# STORAGE_PROVIDER="s3"
# S3_BUCKET_NAME="garmentos-files"
# S3_REGION="auto"
# S3_ACCESS_KEY_ID="your-access-key"
# S3_SECRET_ACCESS_KEY="your-secret-key"
# S3_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
# S3_PUBLIC_URL="https://your-custom-domain.com"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GarmentOS"
NEXT_PUBLIC_COMPANY_NAME="GarmentOS"

# ─── Optional Integrations ────────────────────────────────────────────────────
# WhatsApp (Phase 2)
# WHATSAPP_API_KEY=""
# WHATSAPP_PHONE_NUMBER_ID=""

# SMS via Twilio (Phase 2)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# Vertex AI (Phase 3 - AI document extraction)
# VERTEX_AI_API_KEY="AQ.Ab8RN6KOaSeh_Y-dbeOnjtasQnyFDRCrJBkJa3XzuNuopaDmdA"
# VERTEX_AI_PROJECT_ID=""
# VERTEX_AI_LOCATION="us-central1"
